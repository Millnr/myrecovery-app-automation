{
  "name": "myrecovery-app-automation",
  "version": "1.0.0",
  "private": true,
  "description": "WebdriverIO + TypeScript + Appium 3 E2E automation for the myrecovery patient app (Android): login, dismiss surveys, daily pain check-in, Progress verification, logout.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "wdio run ./wdio.conf.ts",
    "pretest": "node ./scripts/preflight.mjs",
    "postinstall": "appium driver install uiautomator2 || echo 'uiautomator2 driver already installed or install skipped'",
    "doctor": "appium driver doctor uiautomator2",
    "device:check": "adb devices -l",
    "caps:discover": "node ./scripts/discover-caps.mjs",
    "report": "allure generate ./reports/allure-results --single-file --clean -o ./reports/allure-report"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "^22.5.0",
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/appium-service": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "allure-commandline": "^2.29.0",
    "appium": "^3.0.0",
    "appium-uiautomator2-driver": "^8.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
