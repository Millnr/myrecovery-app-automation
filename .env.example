# Copy to `.env` to override any of the defaults baked into config/capabilities.ts.
# The suite runs with the committed defaults below out of the box, so `.env` is optional.

# --- Device under test (discovered via `adb devices -l`) -----------------------
# Leave DEVICE_UDID blank to auto-target the only connected device.
DEVICE_UDID=A2FCCP5912200515
DEVICE_NAME=HONOR X6c
PLATFORM_VERSION=15

# --- App under test (discovered via `adb shell pm list packages` + resolve-activity)
APP_PACKAGE=fhw.com.myrecovery
APP_ACTIVITY=.launch.LaunchActivity

# --- Test account (demo credentials supplied with the exercise) ----------------
# demouser1a is the account HOPCo provided for the automation (surveys intact).
PATIENT_EMAIL=demouser1a@test.mr
PATIENT_PASSWORD=foofooF@0

# --- Appium server -------------------------------------------------------------
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723
